{
	"manifest_version": 2,
	"name": "YouTube ID Grabber",
	"version": "1.0",
	"description": "Grab YouTube IDs.",
	"permissions": [
		"menus",
		"activeTab",
		"clipboardWrite",
		"<all_urls>"
	],
	"background": {
		"scripts": ["background.js"]
	},
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["content.js"],
			"run_at": "document_idle",
			"all_frames": true
		}
	]
}